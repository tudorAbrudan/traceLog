{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && case \"$f\" in *.go) gofmt -w \"$f\" ;; esac; } 2>/dev/null || true",
            "statusMessage": "gofmt..."
          },
          {
            "type": "command",
            "command": "jq -c '{\"systemMessage\": (\"✓ \" + (.tool_input.file_path | split(\"/\") | last) + \" saved\")}' 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Reminder: run make lint && make test before committing.\"}'"
          }
        ]
      }
    ]
  }
}
